{
  "name": "figma-to-claudecode",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Reproduction harness: NativeCamp APP Figma design system as canon, enforced in React.",
  "scripts": {
    "tokens": "node scripts/gen-tokens.mjs",
    "validate": "node scripts/validate-tokens.mjs",
    "dev": "vite",
    "build": "npm run tokens && tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "prebuild": "npm run validate",
    "connect:publish": "figma connect publish",
    "connect:check": "figma connect",
    "shots": "node scripts/shots.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@figma/code-connect": "^1.3.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.5"
  }
}
